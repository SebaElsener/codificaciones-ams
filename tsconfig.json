{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "components/Areas.jsx",
    "components/Portal.jsx",
    "components/Dropdown.jsx",
    "components/CodigoSection.jsx",
    "Screen/Home.jsx",
    "components/Averias.jsx",
    "components/PaperTexture.jsx",
    "components/Gravedades.jsx"
  ]
}
